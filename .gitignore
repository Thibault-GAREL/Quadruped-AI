# IDE
/.idea/
.vscode/
*.iml

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Environnements virtuels
.venv/
venv/
env/

# Outputs : on GARDE les modeles et resultats sur GitHub (necessaires aux
# replays et au partage), on ignore le reste (logs MLflow volumineux).
/outputs/*
!/outputs/models/
!/outputs/results/
# Mais pas les sauvegardes .bak (backups locaux inutiles a partager).
outputs/models/*.bak*
outputs/models/**/*.bak*

# MLflow : base binaire regenerable et volumineuse (les metriques utiles sont
# deja dans outputs/results/*/metrics.json et generations.csv).
/mlruns/
mlflow.db
mlflow.db-journal

# Donnees brutes / volumineuses
/data/1-raw/*
/data/2-processed/*
/data/3-external/*
!/data/1-raw/.gitkeep
!/data/2-processed/.gitkeep
!/data/3-external/.gitkeep

# Fichiers d'environnement
.env
.env.local

# OS
.DS_Store
Thumbs.db
